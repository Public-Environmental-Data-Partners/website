# Copy to .env.local and fill in values. For shared or production values (tokens, secrets, deployment env), contact dev@publicenvirodata.org

NEXT_PUBLIC_SANITY_PROJECT_ID= # Sanity project id
NEXT_PUBLIC_SANITY_DATASET= # Dataset (e.g. `production`)
NEXT_PUBLIC_SANITY_API_VERSION= # API version date string
SANITY_API_READ_TOKEN= # Server-only: read token (private dataset + draft perspective)
SANITY_PREVIEW_SECRET= # Server-only: long random string for /api/draft?secret=...
